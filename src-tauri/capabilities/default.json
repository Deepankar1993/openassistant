{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default-deny baseline plus the folder picker (onboarding) and scoped external-link opening (provider docs).",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "dialog:default",
    {
      "identifier": "opener:allow-open-url",
      "allow": [
        { "url": "https://openrouter.ai/*" },
        { "url": "https://openai.com/*" },
        { "url": "https://platform.openai.com/*" }
      ]
    }
  ]
}
