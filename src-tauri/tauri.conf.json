{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "openAssistant",
  "version": "0.2.2",
  "identifier": "ai.openassistant.desktop",
  "build": {
    "frontendDist": "../frontend"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "openAssistant",
        "width": 1100,
        "height": 760,
        "minWidth": 860,
        "minHeight": 560,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data:; style-src 'self' 'unsafe-inline'; font-src 'self' data:; script-src 'self'; connect-src 'self' ipc: http://ipc.localhost"
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEQ2RDU3QUEyMkI3NTc3Q0YKUldUUGQzVXJvbnJWMW16SGNaVXgyZEVRSDBVV1pzSGdTMm0zeHAvNWY2UEdHczJsNitTTVlOSWUK",
      "endpoints": [
        "https://github.com/Deepankar1993/openassistant/releases/latest/download/latest.json"
      ]
    }
  }
}
